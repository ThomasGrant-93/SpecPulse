# ===========================================
# SpecPulse Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_PASSWORD=specpulse

# ===========================================
# Spring DataSource Configuration
# ===========================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/specpulse
SPRING_DATASOURCE_USERNAME=specpulse
SPRING_DATASOURCE_PASSWORD=specpulse

# ===========================================
# Application Configuration
# ===========================================
